[bootstrap]
main_collection = /example/components/collections/load.collectionc
render = /builtins/render/default.renderc

[script]
shared_state = 1

[display]
width = 960
height = 640

[project]
title = defold-daabbcc3d
dependencies#0 = https://github.com/selimanac/defold-random/archive/refs/heads/master.zip

[library]
include_dirs = daabbcc3d

[daabbcc3d]
max_group_count = 1
max_gameobject_count = 10
max_query_result_count = 10
validate_gameobjects = 1

